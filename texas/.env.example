# Server
PORT=9001
JWT_SECRET=your_jwt_secret_here
JWT_TOKEN_EXPIRES_IN=86400

# Sui Sponsored Transaction
# SPONSOR_PRIVATE_KEY is only used by the backend relayer (tick transactions
# where the sponsor is the sender). Frontend-facing sponsored transactions now
# go through Shinami Gas Station using SHINAMI_API_KEY.
SPONSOR_PRIVATE_KEY=suiprivkey_your_sponsor_private_key_here
SPONSOR_GAS_BUDGET=100000000
# 最后一次 reveal 提交（触发 settle_hand）专用 gas budget，默认 1 SUI
SPONSOR_REVEAL_GAS_BUDGET=1000000000
# Sui fullnode RPC. Public testnet works, but for production rate limits use a
# Shinami node: https://api.us1.shinami.com/sui/node/v1/<YOUR_NODE_KEY>
FULLNODE_URL=https://fullnode.testnet.sui.io:443

# zkLogin Salt Service
ZKLOGIN_SALT_SECRET=change_this_to_a_random_secret

# Shinami access key. Used for:
# 1. zkLogin zkProver (Wallet Services) — proxied via /api/auth/zklogin/prover
# 2. Gas Station (gas sponsorship) — proxied via /api/sponsor/transaction
# The key must be authorized for both services. Get a key at
# https://app.shinami.com (testnet/mainnet only; Shinami does not support devnet).
SHINAMI_API_KEY=your_shinami_access_key

# Sui Event Listener
# Provider: grpc | inodra | both
SUI_EVENT_PROVIDER=grpc
INODRA_WEBHOOK_SECRET=your_inodra_webhook_secret_here
SUI_PACKAGE_ID=0x_your_texas_poker_package_id_here
# 合约首次发布时的原始 Package ID（升级后 struct 类型仍锚定在此 ID）。
# 用于事件过滤和对象类型查询。若未设置，回退到 SUI_PACKAGE_ID。
SUI_ORIGIN_PACKAGE_ID=0x_your_texas_poker_origin_package_id_here
SUI_NETWORK=testnet

# Sui tick task interval in milliseconds (default: 1000)
SUI_TICK_INTERVAL_MS=1000
# Sui system Clock object ID (default: 0x6)
SUI_CLOCK_OBJECT_ID=0x6

# 初始 Table 1 使用的链上 table object ID（环境相关，按部署环境配置）。
# 若未设置，回退到内置测试网默认值。
DEFAULT_CHAIN_TABLE_ID=0xe5736dc65ee19df22daa13c8218ad42c28c31cb5b1f174e73740858371664b33
