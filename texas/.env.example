# Server
PORT=9001
JWT_SECRET=your_jwt_secret_here
JWT_TOKEN_EXPIRES_IN=86400

# Database
MONGO_URI=mongodb://localhost:27017
DB_NAME=zgame

# Initial chips for new users
INITIAL_CHIPS_AMOUNT=1000

# Sui Sponsored Transaction
SPONSOR_PRIVATE_KEY=suiprivkey_your_sponsor_private_key_here
SPONSOR_GAS_BUDGET=100000000
FULLNODE_URL=https://fullnode.testnet.sui.io:443

# zkLogin Salt Service
ZKLOGIN_SALT_SECRET=change_this_to_a_random_secret

# Sui Event Listener
# Provider: grpc | inodra | both
SUI_EVENT_PROVIDER=grpc
INODRA_WEBHOOK_SECRET=your_inodra_webhook_secret_here
SUI_PACKAGE_ID=0x_your_texas_poker_package_id_here
SUI_NETWORK=testnet

# Sui tick task interval in milliseconds (default: 1000)
SUI_TICK_INTERVAL_MS=1000
# Sui system Clock object ID (default: 0x6)
SUI_CLOCK_OBJECT_ID=0x6
